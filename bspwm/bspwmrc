#! /bin/bash

# Kill LXQT/MATE processes that interfere with BSPWM shortcuts
killall -q lxqt-globalkeysd 2>/dev/null
killall -q xbindkeys 2>/dev/null
killall -q mate-settings-daemon 2>/dev/null

# Wait for processes to shut down
sleep 1

# sxhkd - MUST start before anything else to grab keyboard shortcuts
pgrep -x sxhkd > /dev/null || sxhkd &

# Wait for sxhkd to initialize
sleep 1

# bspwm
bspc monitor -d I II III IV V VI VII VIII IX X

bspc config border_width         0
bspc config window_gap          15
bspc config focus_follows_pointer true

bspc config split_ratio          0.50
bspc config borderless_monocle   true
bspc config gapless_monocle      true

# bidirectional clipboard
vmware-user-suid-wrapper &

# fix java error
wmname LG3D &
export _JAVA_AWT_WM_NONREPARENTING=1

# wallpaper
wallpaper=$(cat /home/user_replace/.config/bin/wallpaper)
feh --bg-fill /home/user_replace/Wallpapers/$wallpaper &

# dunst
pgrep -x dunst > /dev/null || dunst &

# brightness
brightness=$(cat /sys/class/backlight/*/brightness)
if [ "$brightness" = "12" ]; then
    echo '0' > /sys/class/backlight/*/brightness
fi

# picom
pgrep -x picom > /dev/null || picom --config /home/user_replace/.config/picom/picom.conf --daemon &

# polybar
if pgrep -x "polybar" > /dev/null
then
    killall -q polybar && sleep 1
fi
polybar &
